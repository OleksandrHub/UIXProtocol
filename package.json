{
  "name": "uixprotocol",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm run build:frontend && tsx ./scripts/server/server.ts",
    "start:laptop-proxy": "tsx ./scripts/tools/laptop-proxy.ts",
    "start:relay": "ssh -R ${RELAY_PORT:-8787}:localhost:${RELAY_PORT:-8787} -o ServerAliveInterval=10 -o ServerAliveCountMax=3 -o ExitOnForwardFailure=yes -N ${RELAY_HOST:-root@178.105.54.231} & npm run start:laptop-proxy -- ${RELAY_PORT:-8787}",
    "build": "npm run build:frontend && tsc",
    "build:frontend": "npm run build:html && npm run build:css",
    "build:assets": "npm run build:frontend",
    "build:html": "tsx ./scripts/tools/build-html.ts",
    "build:html:watch": "tsx ./scripts/tools/build-html.ts --watch",
    "build:css": "sass styles/style.scss public/style.css",
    "build:css:watch": "sass --watch styles/style.scss:public/style.css",
    "create-admin": "tsx ./scripts/tools/create-admin.ts",
    "decrypt": "tsx ./scripts/tools/decrypt.ts",
    "encrypt-legacy": "tsx ./scripts/tools/encrypt-legacy.ts",
    "migrate": "tsx ./scripts/db/migrate.ts"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true
  },
  "dependencies": {
    "@google/genai": "^2.0.0",
    "better-sqlite3": "^12.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "posthtml": "^0.16.7",
    "posthtml-expressions": "^1.11.4",
    "posthtml-include": "^2.0.1",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
