{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "lib": ["es2022"],
    "types": ["node"]
  },
  "include": [
    "scripts/server.ts",
    "scripts/api.ts",
    "scripts/db.ts",
    "scripts/session.ts",
    "scripts/sgemini.ts",
    "scripts/create-admin.ts",
    "scripts/build-html.ts",
    "scripts/constants.ts",
    "scripts/types.ts",
    "environments/**/*.ts"
  ]
}
