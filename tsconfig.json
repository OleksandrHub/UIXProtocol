{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "lib": ["es2022"],
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "api.ts",
    "db.ts",
    "session.ts",
    "gemini.ts",
    "create-admin.ts",
    "models/build-html.ts",
    "models/constants.ts",
    "models/types.ts",
    "environments/**/*.ts"
  ]
}
